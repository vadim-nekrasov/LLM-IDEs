{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git show:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(file:*)",
      "Bash(tree:*)",
      "Bash(readlink:*)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.anthropic.com)"
    ],
    "deny": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(sudo:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(//Users/*/.aws/credentials)",
      "Read(//Users/*/.ssh/id_*)"
    ]
  },
  "effortLevel": "high",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "disableSkillShellExecution": true,
  "statusLine": {
    "type": "command",
    "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/statusline.ts"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/docs-reminder.ts"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/edit-guard.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "timeout": 30,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format.ts"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/userprompt-context.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.ts"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-end.ts"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-compact.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/final-checks.ts"
          },
          {
            "type": "command",
            "timeout": 5,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-summary.ts"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "timeout": 3,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/notify.ts"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 3,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/permission-request.ts"
          }
        ]
      }
    ]
  }
}
