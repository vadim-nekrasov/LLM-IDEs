{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git show:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(file:*)",
      "Bash(tree:*)",
      "Bash(readlink:*)",
      "Bash(tail:*)",
      "Bash(head:*)",
      "Bash(grep:*)",
      "Bash(npx tsc:*)",
      "Bash(bunx tsc:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run lint:*)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "Skill(final-checking)",
      "Skill(writing-docs)",
      "Skill(searching-solutions)",
      "Skill(searching-solutions-multi)",
      "Skill(researching)"
    ],
    "deny": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(npx eslint:*)",
      "Bash(bunx eslint:*)",
      "Bash(pnpm dlx eslint:*)",
      "Bash(yarn dlx eslint:*)"
    ]
  },
  "effortLevel": "high",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "disableSkillShellExecution": true,
  "skillListingBudgetFraction": 0.02,
  "skillOverrides": {
    "searching-solutions": "on",
    "searching-solutions-multi": "on"
  },
  "statusLine": {
    "type": "command",
    "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/statusline.ts"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/docs-reminder.ts"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/edit-guard.ts"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "timeout": 3,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/set-title.ts \"❓ Claude — your answer\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "timeout": 30,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format.ts"
          }
        ]
      },
      {
        "matcher": "mcp__perplexity__|^Agent$",
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/critical-eval-reminder.ts"
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit|WebFetch|WebSearch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "timeout": 3,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/set-title.ts \"⚙️ Claude — working\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/userprompt-context.ts"
          },
          {
            "type": "command",
            "timeout": 3,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/set-title.ts \"⚙️ Claude — working\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.ts"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 5,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-end.ts"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-compact.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 10,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/final-checks.ts"
          },
          {
            "type": "command",
            "timeout": 30,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-touched.ts"
          },
          {
            "type": "command",
            "timeout": 5,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-summary.ts"
          },
          {
            "type": "command",
            "timeout": 3,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/notify.ts \"Claude Code\" \"Turn complete\""
          },
          {
            "type": "command",
            "timeout": 3,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/set-title.ts \"⏳ Claude — your turn\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "timeout": 3,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/notify.ts \"Claude Code\" \"MCP server requests input\""
          },
          {
            "type": "command",
            "timeout": 3,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/set-title.ts \"❓ Claude — input needed\""
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "timeout": 3,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/set-title.ts \"⏳ Claude — your turn\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 3,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/permission-request.ts"
          },
          {
            "type": "command",
            "timeout": 3,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/notify.ts \"Claude Code\" \"Waiting for your input\""
          },
          {
            "type": "command",
            "timeout": 3,
            "command": "bun \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/set-title.ts \"🔐 Claude — permission\""
          }
        ]
      }
    ]
  }
}
